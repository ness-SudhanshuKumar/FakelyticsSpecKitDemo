# Fakelytics Configuration Template
# Copy this file to .env and update values for your environment

# Application
APP_NAME=Fakelytics
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# Database
DATABASE_URL=postgresql://fakelytics:password@localhost:5432/fakelytics
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# Content Extraction
CONTENT_EXTRACTION_TIMEOUT=30
MAX_CONTENT_SIZE=524288000
DOWNLOADED_MEDIA_DIR=extracted_media

# External Services
OPENAI_API_KEY=sk-your-key-here
SERPAPI_KEY=your-serpapi-key

# Feature Flags
ENABLE_ASYNC_MODE=true
ENABLE_WEBHOOKS=true
ENABLE_RATE_LIMITING=true

# Rate Limiting
RATE_LIMIT_FREE_TIER=100
RATE_LIMIT_PRO_TIER=10000
RATE_LIMIT_ENTERPRISE_TIER=1000000

# Timeouts (seconds)
VERIFICATION_TIMEOUT=60
PIPELINE_TIMEOUT=30
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRIES=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Authentication
API_KEY=dev-key-change-in-production
API_KEY_HEADER=X-API-Key
